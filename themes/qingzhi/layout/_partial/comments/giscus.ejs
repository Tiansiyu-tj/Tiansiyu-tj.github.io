<% if(page.hasOwnProperty('comment') ? page.comment
    : theme.comment.giscus.dataRepo
    && theme.comment.giscus.dataRepoId
) { %>
    <div id="giscus"></div>
    <%
    /* 懒加载：当评论区进入视口 200px 范围才加载 giscus script，
       由 config.comment.lazyLoad 控制（默认 true） */
    var lazy = !theme.comment.hasOwnProperty('lazyLoad') || theme.comment.lazyLoad;
    %>
    <% if(lazy) { %>
    <script>
    (function(){
        var attrs = {
            src: 'https://giscus.app/client.js',
            'data-repo': '<%= theme.comment.giscus.dataRepo %>',
            'data-repo-id': '<%= theme.comment.giscus.dataRepoId %>',
            <% if(theme.comment.giscus.dataCategory) { %>'data-category': '<%= theme.comment.giscus.dataCategory %>',<% } %>
            <% if(theme.comment.giscus.dataCategoryId) { %>'data-category-id': '<%= theme.comment.giscus.dataCategoryId %>',<% } %>
            'data-mapping': '<%= theme.comment.giscus.dataMapping %>',
            <% if(theme.comment.giscus.dataTerm) { %>'data-term': '<%= theme.comment.giscus.dataTerm %>',<% } %>
            <% if(theme.comment.giscus.dataMapping != 'number') { %>'data-strict': '<%= theme.comment.giscus.dataStrict %>',<% } %>
            'data-reactions-enabled': '<%= theme.comment.giscus.dataReactionsEnabled %>',
            'data-emit-metadata': '<%= theme.comment.giscus.dataEmitMetadata %>',
            'data-input-position': '<%= theme.comment.giscus.dataInputPosition %>',
            'data-theme': '<%= theme.comment.giscus.dataTheme %>',
            'data-lang': '<%= theme.comment.giscus.dataLang %>',
            <% if(theme.comment.giscus.dataLoading) { %>'data-loading': '<%= theme.comment.giscus.dataLoading %>',<% } %>
            crossorigin: '<%= theme.comment.giscus.crossorigin %>'
        };
        var el = document.getElementById('giscus');
        if (!el) return;
        var io = new IntersectionObserver(function(entries) {
            if (!entries[0].isIntersecting) return;
            io.disconnect();
            var s = document.createElement('script');
            for (var k in attrs) s.setAttribute(k, attrs[k]);
            s.async = true;
            el.appendChild(s);
        }, { rootMargin: '200px' });
        io.observe(el);
    })();
    </script>
    <% } else { %>
    <script src="https://giscus.app/client.js"
        data-repo="<%= theme.comment.giscus.dataRepo %>"
        data-repo-id="<%= theme.comment.giscus.dataRepoId %>"
        <% if(theme.comment.giscus.dataCategory) { %>
            data-category="<%= theme.comment.giscus.dataCategory %>"
        <% } %>
        <% if(theme.comment.giscus.dataCategoryId) { %>
            data-category-id="<%= theme.comment.giscus.dataCategoryId %>"
        <% } %>
        data-mapping="<%= theme.comment.giscus.dataMapping %>"
        <% if(theme.comment.giscus.dataTerm) { %>
            data-term="<%= theme.comment.giscus.dataTerm %>"
        <% } %>
        <% if(theme.comment.giscus.dataMapping != 'number') { %>
            data-strict="<%= theme.comment.giscus.dataStrict %>"
        <% } %>
        data-reactions-enabled="<%= theme.comment.giscus.dataReactionsEnabled %>"
        data-emit-metadata="<%= theme.comment.giscus.dataEmitMetadata %>"
        data-input-position="<%= theme.comment.giscus.dataInputPosition %>"
        data-theme="<%= theme.comment.giscus.dataTheme %>"
        data-lang="<%= theme.comment.giscus.dataLang %>"
        <% if(theme.comment.giscus.dataLoading) { %>
            data-loading="<%= theme.comment.giscus.dataLoading %>"
        <% } %>
        crossorigin="<%= theme.comment.giscus.crossorigin %>"
        <% if(theme.comment.giscus.async) { %>
            async
        <% } %>
    ></script>
    <% } %>
<% } %>
