<a class="browse-back" href="/tags/">
  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="15 18 9 12 15 6"/></svg>
  全部标签
</a>

<%
var pageTagName = path.substring("tags/".length, path.indexOf("/index.html"));
var tagHashmap = new HashMap();
var allPostArray = site.posts.data;
for (var i = 0; i < allPostArray.length; i++) {
  var postTemp = allPostArray[i];
  var postTempTags = postTemp.tags.data;
  for (var j = 0; j < postTempTags.length; j++) {
    if (!tagHashmap.containsKey(postTempTags[j].name)) {
      tagHashmap.put(postTempTags[j].name, [postTemp]);
    } else {
      tagHashmap.get(postTempTags[j].name).push(postTemp);
    }
  }
}
var array = tagHashmap.containsKey(pageTagName) ? tagHashmap.get(pageTagName) : [];
if (Array.isArray(array)) {
  array.sort(function(a, b) { return b.date - a.date; });
}
var visiblePosts = array.filter(function(p) { return !('hide' in p) || p.hide === false; });
%>

<div class="subpage-title">📌 <i><%= pageTagName %></i></div>

<div class="subpage-list">
  <% for (var i = 0; i < visiblePosts.length; i++) { var p = visiblePosts[i]; %>
    <a class="subpage-item" href="<%- url_for(p.path) %>">
      <span class="subpage-date"><%= date(p.date, "YYYY-MM-DD") %></span>
      <span class="subpage-name"><%= p.title %></span>
    </a>
  <% } %>
</div>
